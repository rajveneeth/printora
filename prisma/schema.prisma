generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SellerVerificationStatus {
  NOT_APPLIED
  PENDING
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
}

enum AddressKind {
  SHIPPING
  BILLING
  BOTH
}

enum CheckoutStatus {
  CREATED
  PAYMENT_PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum PaymentProvider {
  MOCK
  RAZORPAY
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String             @unique
  emailVerified     Boolean            @default(false)
  image             String?
  role              UserRole           @default(CUSTOMER)
  status            AccountStatus      @default(ACTIVE)
  phone             String?
  lastActiveAt      DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  accounts          Account[]
  buyerProfile      BuyerProfile?
  sellerProfile     SellerProfile?
  sellerApplication SellerApplication?
  addresses         Address[]
  favourites        Favourite[]
  carts             Cart[]
  orders            Order[]            @relation("BuyerOrders")
  checkoutSessions  CheckoutSession[]
  reviews           Review[]
  sellerReviews     SellerReview[]
  auditLogs         AuditLog[]
}

model Session {
  id               String            @id @default(cuid())
  token            String            @unique
  userId           String
  expiresAt        DateTime
  revokedAt        DateTime?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  carts            Cart[]
  cartMerges       CartMerge[]
  checkoutSessions CheckoutSession[]

  @@index([userId, createdAt])
  @@index([expiresAt, revokedAt])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model BuyerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  displayName      String
  defaultAddressId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerProfile {
  id                  String                   @id @default(cuid())
  userId              String                   @unique
  storeName           String
  storeSlug           String                   @unique
  description         String
  logoUrl             String?
  bannerUrl           String?
  contactEmail        String
  contactPhone        String?
  originCity          String
  originState         String
  originPostalCode    String
  yearsExperience     Int                      @default(0)
  supportedMaterials  String[]
  printTechnologies   String[]
  maxPrintDimensions  String?
  customOrdersEnabled Boolean                  @default(true)
  averageProcessDays  Int                      @default(5)
  verificationStatus  SellerVerificationStatus @default(NOT_APPLIED)
  averageRating       Decimal                  @default(0) @db.Decimal(3, 2)
  completedOrderCount Int                      @default(0)
  cancellationRate    Decimal                  @default(0) @db.Decimal(5, 2)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  products            Product[]
  orderFulfilments    SellerOrderFulfilment[]
  reviews             SellerReview[]
  moderationEvents    SellerModerationEvent[]
}

model SellerApplication {
  id                  String                   @id @default(cuid())
  userId              String                   @unique
  storeName           String
  storeSlug           String
  description         String
  logoUrl             String?
  bannerUrl           String?
  contactEmail        String
  contactPhone        String?
  originCity          String
  originState         String
  originPostalCode    String
  yearsExperience     Int                      @default(0)
  supportedMaterials  String[]
  printTechnologies   String[]
  maxPrintDimensions  String?
  customOrdersEnabled Boolean                  @default(true)
  averageProcessDays  Int                      @default(5)
  declarationAccepted Boolean                  @default(false)
  status              SellerVerificationStatus @default(PENDING)
  submittedAt         DateTime                 @default(now())
  reviewedAt          DateTime?
  changeRequestNote   String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, submittedAt])
}

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  description    String?
  imageUrl       String?
  icon           String?
  seoTitle       String?
  seoDescription String?
  parentId       String?
  position       Int        @default(0)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  parent         Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryTree")
  products       Product[]
}

model Product {
  id                   String                 @id @default(cuid())
  sellerId             String
  categoryId           String
  name                 String
  slug                 String                 @unique
  shortDescription     String
  fullDescription      String
  basePrice            Decimal                @db.Decimal(10, 2)
  compareAtPrice       Decimal?               @db.Decimal(10, 2)
  currency             String                 @default("INR")
  sku                  String                 @unique
  minOrderQuantity     Int                    @default(1)
  maxOrderQuantity     Int?
  dimensions           String?
  weightGrams          Int?
  material             String
  finish               String?
  colour               String?
  processingDays       Int                    @default(5)
  shippingOrigin       String
  customisationEnabled Boolean                @default(false)
  safetyNotes          String?
  intendedUse          String?
  ageRestriction       String?
  ipDeclaration        String
  tags                 String[]               @default([])
  searchKeywords       String[]
  seoTitle             String?
  seoDescription       String?
  status               ProductStatus          @default(DRAFT)
  viewCount            Int                    @default(0)
  publishedAt          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  seller               SellerProfile          @relation(fields: [sellerId], references: [id])
  category             Category               @relation(fields: [categoryId], references: [id])
  images               ProductImage[]
  variants             ProductVariant[]
  inventory            Inventory?
  favourites           Favourite[]
  cartItems            CartItem[]
  orderItems           OrderItem[]
  reviews              Review[]
  approvalEvents       ProductApprovalEvent[]

  @@index([status, publishedAt])
  @@index([sellerId, updatedAt])
  @@index([categoryId, status])
  @@index([createdAt])
  @@index([basePrice])
}

model ProductApprovalEvent {
  id             String         @id @default(cuid())
  productId      String
  actorId        String
  previousStatus ProductStatus?
  newStatus      ProductStatus
  note           String?
  createdAt      DateTime       @default(now())
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  name       String
  sku        String      @unique
  material   String?
  colour     String?
  finish     String?
  priceDelta Decimal     @default(0) @db.Decimal(10, 2)
  isActive   Boolean     @default(true)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  Inventory?
  cartItems  CartItem[]
  orderItems OrderItem[]
}

model Inventory {
  id                String          @id @default(cuid())
  productId         String?         @unique
  variantId         String?         @unique
  quantity          Int             @default(0)
  reserved          Int             @default(0)
  lowStockThreshold Int             @default(5)
  updatedAt         DateTime        @updatedAt
  product           Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant           ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Favourite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  sessionId String?
  currency  String     @default("INR")
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   Session?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  items     CartItem[]
  merges    CartMerge[]

  @@index([sessionId])
  @@index([expiresAt])
}

model CartItem {
  id            String          @id @default(cuid())
  cartId        String
  lineKey       String
  productId     String
  variantId     String?
  quantity      Int
  customisation String?
  unitPrice     Decimal         @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cart          Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, lineKey])
}

model CartMerge {
  id          String   @id @default(cuid())
  cartId      String
  sessionId   String?
  guestCartId String
  mergedAt    DateTime @default(now())
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([cartId, guestCartId])
  @@index([sessionId, mergedAt])
}

model RateLimitBucket {
  key         String   @id
  count       Int      @default(1)
  windowStart DateTime
  expiresAt   DateTime
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model Address {
  id         String      @id @default(cuid())
  userId     String
  kind       AddressKind @default(SHIPPING)
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String      @default("India")
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id            String                  @id @default(cuid())
  orderNumber   String                  @unique
  buyerId       String
  status        OrderStatus             @default(PENDING_PAYMENT)
  currency      String                  @default("INR")
  subtotal      Decimal                 @db.Decimal(10, 2)
  taxTotal      Decimal                 @default(0) @db.Decimal(10, 2)
  shippingTotal Decimal                 @default(0) @db.Decimal(10, 2)
  grandTotal    Decimal                 @db.Decimal(10, 2)
  placedAt      DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  buyer         User                    @relation("BuyerOrders", fields: [buyerId], references: [id])
  items         OrderItem[]
  address       OrderAddress?
  checkout      CheckoutSession?
  payments      Payment[]
  statusEvents  OrderStatusEvent[]
  fulfilments   SellerOrderFulfilment[]

  @@index([buyerId, placedAt])
  @@index([status, placedAt])
}

model OrderItem {
  id                    String          @id @default(cuid())
  orderId               String
  productId             String?
  variantId             String?
  sellerId              String
  productNameSnapshot   String
  sellerNameSnapshot    String
  variantSnapshot       Json?
  customisationSnapshot String?
  productImageSnapshot  String?
  quantity              Int
  unitPrice             Decimal         @db.Decimal(10, 2)
  tax                   Decimal         @default(0) @db.Decimal(10, 2)
  shippingFee           Decimal         @default(0) @db.Decimal(10, 2)
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant               ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  review                Review?
  sellerReview          SellerReview?

  @@index([sellerId])
}

model OrderAddress {
  id         String      @id @default(cuid())
  orderId    String      @unique
  kind       AddressKind @default(SHIPPING)
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String      @default("India")
  createdAt  DateTime    @default(now())
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderStatusEvent {
  id             String       @id @default(cuid())
  orderId        String
  sellerId       String?
  actorId        String?
  previousStatus OrderStatus?
  status         OrderStatus
  note           String?
  createdAt      DateTime     @default(now())
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model SellerOrderFulfilment {
  id             String        @id @default(cuid())
  orderId        String
  sellerId       String
  status         OrderStatus
  trackingNumber String?
  carrier        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seller         SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  @@unique([orderId, sellerId])
  @@index([sellerId, status, updatedAt])
}

model CheckoutSession {
  id             String          @id @default(cuid())
  userId         String
  sessionId      String?
  orderId        String          @unique
  addressId      String
  idempotencyKey String          @unique
  status         CheckoutStatus  @default(CREATED)
  provider       PaymentProvider
  expiresAt      DateTime
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session        Session?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment        Payment?

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([status, expiresAt])
}

model Payment {
  id                String          @id @default(cuid())
  checkoutSessionId String          @unique
  orderId           String
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("INR")
  providerOrderId   String?         @unique
  providerPaymentId String?         @unique
  failureReason     String?
  verifiedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  checkoutSession   CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events            PaymentEvent[]

  @@index([orderId, createdAt])
  @@index([status, createdAt])
}

model PaymentEvent {
  id              String   @id @default(cuid())
  paymentId       String
  providerEventId String   @unique
  eventType       String
  payload         Json
  processedAt     DateTime @default(now())
  payment         Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, processedAt])
}

model Review {
  id               String                  @id @default(cuid())
  productId        String
  authorId         String
  orderItemId      String?                 @unique
  rating           Int
  qualityRating    Int
  finishRating     Int
  accuracyRating   Int
  valueRating      Int
  title            String
  body             String
  status           ReviewStatus            @default(PENDING)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  product          Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  author           User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  orderItem        OrderItem?              @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  moderationEvents ReviewModerationEvent[]

  @@index([productId, status, createdAt])
}

model SellerReview {
  id                  String                  @id @default(cuid())
  sellerId            String
  authorId            String
  orderItemId         String                  @unique
  rating              Int
  communicationRating Int
  dispatchSpeedRating Int
  customisationRating Int
  status              ReviewStatus            @default(PUBLISHED)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  seller              SellerProfile           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  author              User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  orderItem           OrderItem               @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  moderationEvents    ReviewModerationEvent[]

  @@index([sellerId, status, createdAt])
}

model ReviewModerationEvent {
  id             String        @id @default(cuid())
  reviewId       String?
  sellerReviewId String?
  moderatorId    String
  previousStatus ReviewStatus
  newStatus      ReviewStatus
  reason         String
  createdAt      DateTime      @default(now())
  review         Review?       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  sellerReview   SellerReview? @relation(fields: [sellerReviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
  @@index([sellerReviewId, createdAt])
}

model SellerModerationEvent {
  id             String                   @id @default(cuid())
  sellerId       String
  moderatorId    String
  previousStatus SellerVerificationStatus
  newStatus      SellerVerificationStatus
  reason         String?
  createdAt      DateTime                 @default(now())
  seller         SellerProfile            @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String
  action        String
  entityType    String
  entityId      String
  previousState Json?
  newState      Json?
  reason        String?
  createdAt     DateTime @default(now())
  actor         User     @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}
