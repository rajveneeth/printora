{
  "name": "formivo-3d",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "echo \"Quality checks are deferred until the hardening phase\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "precommit": "lint-staged",
    "prepush": "pnpm ci"
  },
  "dependencies": {
    "@next/env": "latest",
    "@tailwindcss/postcss": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest",
    "@prisma/client": "latest"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@eslint/eslintrc": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/jest": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "husky": "latest",
    "jest": "latest",
    "jest-environment-jsdom": "latest",
    "lint-staged": "latest",
    "postcss": "latest",
    "prettier": "latest",
    "sass": "latest",
    "tailwindcss": "latest",
    "ts-jest": "latest",
    "typescript": "latest",
    "prisma": "latest",
    "tsx": "latest"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,scss,css,yml,yaml}": [
      "prettier --check"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
