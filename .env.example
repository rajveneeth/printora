NEXT_PUBLIC_APP_URL="http://localhost:3000"
DATABASE_URL="postgresql://formivo:formivo@localhost:5432/formivo"
# Server-only pepper used to hash rate-limit identifiers. Generate with: openssl rand -base64 32
RATE_LIMIT_SECRET="replace-with-at-least-32-random-characters"

# Use mock for a credential-free local simulation or razorpay for a configured provider.
PAYMENT_PROVIDER="mock"
ALLOW_MOCK_PAYMENTS_IN_PRODUCTION="false"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Customer dashboard configuration
CUSTOMER_DASHBOARD_ENABLED="true"

# Seller dashboard and product-media configuration
SELLER_DASHBOARD_ENABLED="true"
SELLER_IMAGE_MAX_COUNT="8"
SELLER_IMAGE_MAX_BYTES="5242880"

# Admin dashboard configuration
ADMIN_DASHBOARD_ENABLED="true"
